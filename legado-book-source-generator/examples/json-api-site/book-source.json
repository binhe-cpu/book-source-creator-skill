[{
  "bookSourceUrl": "https://api-example.com",
  "bookSourceName": "JSON API 样例",
  "searchUrl": "https://api-example.com/api/search?q={{key}}&page={{page}}",
  "ruleSearch": {
    "bookList": "$.data.list[*]",
    "name": "$.title",
    "bookUrl": "/api/book/{{$.id}}"
  },
  "ruleBookInfo": {
    "name": "$.data.title",
    "author": "$.data.author",
    "coverUrl": "$.data.cover",
    "intro": "$.data.intro",
    "tocUrl": "/api/book/{{$.id}}/chapters"
  },
  "ruleToc": {
    "chapterList": "$.data.chapters[*]",
    "chapterName": "$.title",
    "chapterUrl": "/api/chapter/{{$.id}}"
  },
  "ruleContent": {
    "content": "$.data.content"
  }
}]