[{
  "bookSourceUrl": "https://webview-example.com",
  "bookSourceName": "WebView回退样例",
  "searchUrl": "https://webview-example.com/search?q={{key}}",
  "ruleSearch": {
    "bookList": ".search-results .book-item",
    "name": ".book-title",
    "bookUrl": "a@href"
  },
  "ruleBookInfo": {
    "name": ".book-title",
    "author": ".book-author",
    "coverUrl": ".book-cover img@src",
    "intro": ".book-desc",
    "tocUrl": ".toc-link@href"
  },
  "ruleToc": {
    "chapterList": ".chapter-list a",
    "chapterName": "text",
    "chapterUrl": "tag.a@href##$##,{\"webView\":true}"
  },
  "ruleContent": {
    "content": "#chapter-content@html"
  }
}]